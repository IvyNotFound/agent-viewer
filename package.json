{
  "name": "agent-viewer",
  "version": "0.3.0",
  "description": "Interface desktop Trello/Jira pour visualiser les agents Claude",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "node scripts/download-sqlite3.js && electron-vite build && electron-builder --win",
    "build:dir": "node scripts/download-sqlite3.js && electron-vite build && electron-builder --win --dir",
    "preview": "electron-vite preview",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "node scripts/check-sqlite3.js",
    "download-sqlite3": "node scripts/download-sqlite3.js",
    "release": "bash scripts/release.sh",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "codemirror": "^6.0.2",
    "node-pty": "^1.0.0",
    "node-sqlite3-wasm": "^0.8.53",
    "pinia": "^2.1.7",
    "sql.js": "^1.14.0",
    "vue": "^3.4.15"
  },
  "overrides": {
    "minimatch": "^10.0.0",
    "tar": "^7.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@pinia/testing": "^0.1.7",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.17",
    "electron": "^28.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.3",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^3.2.5"
  }
}
