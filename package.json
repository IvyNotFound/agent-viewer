{
  "name": "agent-viewer",
  "version": "0.3.0",
  "description": "Interface desktop Trello/Jira pour visualiser les agents Claude",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "node scripts/download-sqlite3.js && electron-vite build && electron-builder --win",
    "build:dir": "node scripts/download-sqlite3.js && electron-vite build && electron-builder --win --dir",
    "preview": "electron-vite preview",
    "lint": "eslint src --ext .ts,.vue",
    "test": "echo \"no tests configured yet\"",
    "postinstall": "node scripts/check-sqlite3.js",
    "download-sqlite3": "node scripts/download-sqlite3.js",
    "release": "bash scripts/release.sh",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@xterm/addon-fit": "^0.10.0",
    "codemirror": "^6.0.2",
    "node-pty": "^1.0.0",
    "node-sqlite3-wasm": "^0.8.53",
    "pinia": "^2.1.7",
    "sql.js": "^1.14.0",
    "vue": "^3.4.15",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^20.11.5",
    "@vitejs/plugin-vue": "^5.0.3",
    "autoprefixer": "^10.4.17",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vue-tsc": "^1.8.27"
  }
}
