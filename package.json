{
  "name": "agent-viewer",
  "version": "0.25.0",
  "description": "Interface desktop Trello/Jira pour visualiser les agents Claude",
  "author": "IvyNotFound",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "node scripts/download-sqlite3.js && electron-vite build && electron-builder --win",
    "build:win": "node scripts/download-sqlite3.js && electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:vite": "node scripts/download-sqlite3.js && electron-vite build",
    "build:dir": "node scripts/download-sqlite3.js && electron-vite build && electron-builder --win --dir",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "test:mutation:renderer": "stryker run stryker.renderer.config.mjs",
    "test:mutation:main": "stryker run stryker.main.config.mjs",
    "stryker:file": "stryker run --mutate",
    "stryker:bg": "bash scripts/stryker-run.sh",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:update": "playwright test --config playwright.config.ts --update-snapshots",
    "download-sqlite3": "node scripts/download-sqlite3.js",
    "release": "bash scripts/release.sh",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major",
    "i18n:check": "node scripts/check-i18n.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "sql.js": "^1.14.0"
  },
  "overrides": {
    "minimatch": "^10.0.0",
    "tar": "^7.0.0"
  },
  "devDependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@playwright/test": "^1.58.2",
    "@pinia/testing": "^0.1.7",
    "playwright": "^1.58.2",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.13.5",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.17",
    "codemirror": "^6.0.2",
    "dompurify": "^3.2.7",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "highlight.js": "^11.11.1",
    "jsdom": "^26.1.0",
    "marked": "^17.0.3",
    "pinia": "^2.1.7",
    "postcss": "^8.4.33",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18",
    "vue": "^3.4.15",
    "vue-i18n": "^9.14.5",
    "vue-tsc": "^3.2.5"
  }
}
