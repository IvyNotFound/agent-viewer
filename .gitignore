# Dependencies
node_modules/

# Build outputs
out/
dist/

# Electron builder
release/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Local env
.env
.env.local

# SQLite temp/lock files
*.db-journal
*.db-wal
*.db-shm

# Project DB (generated)
.claude/*.db
.claude/*.db.bak
.claude/*.db.tmp
.claude/*.db.tmp.*
.claude/*.db.backup-*
.claude/*.dbb
.claude/*.dbb*

# Bundled binaries (downloaded at build time)
resources/bin/*.exe
resources/bin/*.zip

# Build artifacts (electron-builder output) — except source assets
build/*
!build/icon.png
!build/icon.ico
!build/installer.nsh
tsconfig.node.tsbuildinfo
tsconfig.web.tsbuildinfo


# Misc
SELECT
.claude/project-db
.claude/project_db
.claude/worktrees/

# Local debug/memory dumps
mem-dump-*.json
mem-dump-*.txt
scripts/mem-dump.ps1

# Accidental tilde-expansion artefact
~/

# Playwright E2E test artifacts (generated)
playwright-report/
test-results/
.stryker-tmp/
.strykerignore

# Stryker background run logs and status
logs/

# Test coverage (generated)
coverage/

# Mutation testing output (generated)
mutation/
